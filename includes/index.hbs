<!DOCTYPE html>
<html lang="zh">
<head>
    <title>{{site_title}}</title>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="robots" content="noindex, nofollow"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <link rel="shortcut icon" type="image/x-icon" href="favicon.ico"/>
    <link href="index.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.15.1/dist/katex.min.css"
          integrity="sha384-R4558gYOUz8mP9YWpZJjofhk+zx0AS11p36HnD2ZKj/6JR5z27gSSULCNHIRReVs" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.15.1/dist/katex.min.js"
            integrity="sha384-z1fJDqw8ZApjGO3/unPWUPsIymfsJmyrDVWC8Tv/a1HeOtGmkwNd/7xUS0Xcnvsx" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.15.1/dist/contrib/auto-render.min.js"
            integrity="sha384-+XBljXPPiv+OzfbB3cVmLHf4hdUFHlWNZN5spNQ7rmHTXpd7WvJum6fIACpNNfIR" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            renderMathInElement(document.body, {
                delimiters: [
                    {left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},
                    {left:'\\(',right:'\\)',display:false},{left:'\\[',right:'\\]',display:true},
                    {left:"\\begin{equation}",right:"\\end{equation}",display:true},
                    {left:"\\begin{align}",right:"\\end{align}",display:true},
                ],
                throwOnError: false
            });
        });
    </script>
</head>

<body>

<!-- ═══════ HEADER ═══════ -->
<header class="header-container">
    <div class="header-inner">
        <a class="header-logo" href="https://github.com/Wastoon/3DArxiv" title="GitHub">
            <span class="logo-3d">3D</span><span class="logo-arxiv">Arxiv</span>
        </a>

        <div class="header-search">
            <div class="search-wrap">
                <i class="ri-search-line search-icon"></i>
                <input type="text" id="search-input" placeholder="搜索标题、作者、摘要… (Press / )" autocomplete="off" spellcheck="false"/>
                <kbd class="search-shortcut">/</kbd>
            </div>
            <button id="featured-toggle" title="只看精选 (顶级作者 / 顶会)">
                <i class="ri-award-line"></i><span>精选</span>
            </button>
        </div>

        <div class="header-actions">
            <button id="stats-btn" class="hbtn" title="统计图表">
                <i class="ri-bar-chart-2-line"></i>
            </button>
            <button id="bookmarks-btn" class="hbtn" title="我的收藏">
                <i class="ri-bookmark-line"></i>
                <span id="bookmark-count" class="badge hidden">0</span>
            </button>
            <label class="hbtn theme-switch" for="checkbox" title="切换主题">
                <input type="checkbox" id="checkbox"/>
                <i id="theme-icon" class="ri-moon-line"></i>
            </label>
            <a class="hbtn" href="https://github.com/Wastoon/3DArxiv" target="_blank" rel="noopener" title="GitHub">
                <i class="ri-github-line"></i>
            </a>
        </div>
    </div>
</header>

<!-- Featured Legend -->
<div id="featured-legend" class="featured-legend hidden">
    <div class="fl-items">
        <div class="fl-item"><span class="hl-star">★★</span> 顶级作者 + 顶级机构</div>
        <div class="fl-item"><span class="hl-star">★</span> 顶级作者 或 顶级机构</div>
        <div class="fl-item"><span class="chip">Conference</span> 已在顶会发表</div>
    </div>
    <button class="fl-close" id="legend-close">&times;</button>
</div>

<!-- ═══════ STATS DASHBOARD (hidden by default) ═══════ -->
<section id="stats-dashboard" class="stats-dashboard hidden">
    <div class="stats-dashboard-inner">
        <div class="sd-header">
            <h2 class="sd-title"><i class="ri-bar-chart-2-line"></i> 论文统计</h2>
            <button class="sd-close" id="stats-close"><i class="ri-close-line"></i></button>
        </div>
        <div class="sd-kpi-row">
            <div class="kpi-card">
                <div class="kpi-val" id="kpi-total">—</div>
                <div class="kpi-label">论文总数</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-val" id="kpi-days">—</div>
                <div class="kpi-label">统计天数</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-val" id="kpi-avg">—</div>
                <div class="kpi-label">日均论文</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-val" id="kpi-top">—</div>
                <div class="kpi-label">顶会/大牛论文</div>
            </div>
        </div>
        <div class="sd-charts">
            <div class="chart-card chart-card--wide">
                <div class="chart-card-title">每日论文数量趋势</div>
                <div class="chart-wrap"><canvas id="chart-daily"></canvas></div>
            </div>
            <div class="chart-card">
                <div class="chart-card-title">各领域论文分布</div>
                <div class="chart-wrap"><canvas id="chart-subjects"></canvas></div>
            </div>
            <div class="chart-card">
                <div class="chart-card-title">顶会论文 vs 普通论文</div>
                <div class="chart-wrap chart-wrap--donut"><canvas id="chart-featured"></canvas></div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ SUMMARY BAR ═══════ -->
<div class="summary-bar">
    <div class="summary-bar-inner">
        <span id="sb-total" class="sb-stat">— 篇</span>
        <span class="sb-sep">·</span>
        <span id="sb-days" class="sb-stat">— 天</span>
        <span class="sb-sep">·</span>
        <span id="sb-top" class="sb-stat sb-highlight">— 篇精选</span>
        <span class="sb-right">
            <kbd class="kb">Tab</kbd> 展开/折叠全部
            &nbsp;&nbsp;
            <kbd class="kb">/</kbd> 搜索
        </span>
    </div>
</div>

<!-- ═══════ MAIN ═══════ -->
<main class="main-content">

{{#each days}}
<section class="day-section">
    <div class="day-header">
        <span class="day-date"><time datetime="{{datetime}}">{{time_format datetime "%m月%d日"}}</time></span>
        <span class="day-weekday" data-datetime="{{datetime}}"></span>
        <div class="day-divider"></div>
        <span class="day-year" data-datetime="{{datetime}}"></span>
    </div>

    {{#each subjects}}
    <div class="subject-block">
        <details>
            <summary class="subject-summary">
                <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0L14.414 10l-5.707 5.707a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                <span class="subject-name">{{ subject }}</span>
                <span class="subject-pill">{{len papers}}</span>
            </summary>
            <div class="subject-body">
                {{#each papers}}
                <div class="paper-item"
                     data-title="{{title}}"
                     data-authors="{{authors}}"
                     data-conference="{{#if comment}}1{{else}}0{{/if}}">
                    <details>
                        <summary class="paper-summary">
                            <span class="paper-star-col">{{highlight_title title authors comment}}</span>
                            <span class="paper-title-wrap">
                                {{#if (ne updated published)}}<span class="updated-badge" title="已更新">♻</span>{{/if}}<span class="paper-title">{{title}}</span>{{#if comment}}&nbsp;{{highlight_conference comment}}{{/if}}
                            </span>
                            <svg class="paper-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0L14.414 10l-5.707 5.707a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                        </summary>
                        <div class="paper-body">
                            <div class="paper-actions">
                                <a class="paction paction--link" href="{{id}}" target="_blank" rel="noopener">
                                    <i class="ri-links-line"></i> arXiv
                                </a>
                                <a class="paction paction--pdf" href="{{pdf_url}}" target="_blank" rel="noopener">
                                    <i class="ri-file-pdf-2-line"></i> PDF
                                </a>
                                <button class="paction paction--ai ai-summary-btn"
                                        data-title="{{title}}"
                                        data-abstract="">
                                    <i class="ri-sparkling-2-line"></i> AI 中文摘要
                                </button>
                                <button class="paction paction--bm bookmark-btn"
                                        data-id="{{id}}"
                                        data-url="{{id}}"
                                        title="收藏此论文">
                                    <i class="ri-bookmark-line"></i>
                                </button>
                            </div>
                            <div class="paper-authors">{{highlight_author authors}}</div>
                            <div class="paper-abstract">{{summary}}</div>
                            {{#if comment}}
                            <div class="paper-comment"><span class="chip chip--sm">comment</span> {{comment}}</div>
                            {{/if}}
                        </div>
                    </details>
                </div>
                {{/each}}
            </div>
        </details>
    </div>
    {{/each}}
</section>
{{/each}}

</main>

<!-- ═══════ BOOKMARKS PANEL ═══════ -->
<div id="panel-overlay" class="panel-overlay"></div>
<aside id="bookmarks-panel" class="bookmarks-panel">
    <div class="bp-header">
        <span class="bp-title"><i class="ri-bookmark-fill"></i> 收藏夹</span>
        <button class="bp-close" id="bp-close"><i class="ri-close-line"></i></button>
    </div>
    <div class="bp-body" id="bp-body">
        <div class="bp-empty">
            <i class="ri-bookmark-line" style="font-size:2.8rem"></i><br>
            暂无收藏
        </div>
    </div>
    <div class="bp-footer">
        <button id="bp-export" class="bp-export-btn"><i class="ri-download-line"></i> 导出为文本</button>
    </div>
</aside>

<!-- ═══════ FOOTER ═══════ -->
<footer class="site-footer">
    <div class="site-footer-inner">
        <span class="footer-brand">3DArxiv</span>
        <span class="footer-sep">·</span>
        <span class="footer-powered">Powered by <a href="https://github.com/MLNLP-World/MyArxiv" target="_blank">MyArxiv</a></span>
        <span class="footer-right">
            <time id="build-timestamp" datetime="{{build_time}}">
                <a href="https://github.com/Wastoon/3DArxiv/actions" target="_blank" style="color:inherit">
                    更新于 {{time_format build_time "%F %T"}} UTC
                </a>
            </time>
        </span>
    </div>
</footer>

<script src="index.js"></script>
</body>
</html>
